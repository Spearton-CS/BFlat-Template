<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<PackageId>Spearton.BFlat.Template</PackageId>
		<PackageType>Template</PackageType>
		<Version>1.0.0</Version>
		<Authors>Spearton-CS</Authors>
		<Description>VisualStudio-ready BFLAT template with UI parameters, Intellisense and F5 support.</Description>
		<RepositoryUrl>https://github.com/Spearton-CS/BFlat-Template</RepositoryUrl>
		<PackageTags>csharp;bflat;nativeaot;template;native;net10.0</PackageTags>

		<TargetFramework>net10.0</TargetFramework>
		<IncludeContentInPack>true</IncludeContentInPack>
		<IncludeBuildOutput>false</IncludeBuildOutput>
		<ContentTargetFolders>content</ContentTargetFolders>

		<NoDefaultExcludes>true</NoDefaultExcludes>
		<GeneratePackageOnBuild>false</GeneratePackageOnBuild>
	</PropertyGroup>

	<ItemGroup>
		<Content Include="Template\**\*"
				 Exclude="Template\**\bin\**;Template\**\obj\**"
				 Pack="true"
				 PackagePath="content\" />

		<None Include="README.md" Pack="true" PackagePath="\" />
	</ItemGroup>
</Project>